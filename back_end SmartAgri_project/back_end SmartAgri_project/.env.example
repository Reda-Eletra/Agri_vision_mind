# Server
PORT=4000
NODE_ENV=development

# Database
# DB_MODE:
#   auto     -> try PostgreSQL first, fallback to pg-mem in non-production
#   postgres -> force PostgreSQL (recommended for production)
#   memory   -> force pg-mem (development/testing only)
DB_MODE=auto
# Only used when DB_MODE=auto and NODE_ENV is not production
DB_FALLBACK_TO_MEMORY=true

# PostgreSQL
# (used when DB_MODE=postgres, or DB_MODE=auto before fallback)
# DATABASE_URL=postgresql://user:password@localhost:5432/smart_agriculture
DB_USER=postgres
DB_HOST=localhost
DB_NAME=smart_agriculture
DB_PASSWORD=postgres
DB_PORT=5432
DB_SSL=false

# JWT
JWT_SECRET=change_this_to_a_strong_secret
JWT_EXPIRES_IN=7d

# Admin users (comma-separated emails)
ADMIN_EMAILS=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Email (Nodemailer)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Smart Agriculture <noreply@smartagri.com>"

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Gemini AI for backend Plant Doctor endpoints
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# News sync
# Set to false to disable the automatic importer
NEWS_SYNC_ENABLED=true
# Automatic sync interval in minutes
NEWS_SYNC_INTERVAL_MINUTES=30
# Maximum number of article URLs to scan per source on each run
NEWS_SYNC_MAX_ARTICLES_PER_SOURCE=8
# Delay before the first automatic sync after server startup (milliseconds)
NEWS_SYNC_STARTUP_DELAY_MS=5000
